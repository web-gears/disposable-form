{
  "name": "form-session-service",
  "version": "1.0.1",
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:esbuild",
    "build:ui": "npm run build:form && npm run build:landing && npm run build:error && npm run copy:html",
    "copy:html": "cp src/ui/landing.html src/ui/error.html src/ui/index.html src/ui/favicon.svg dist/ui/",
    "build:form": "esbuild src/ui/FormRenderer.tsx --bundle --format=iife --global-name=FormApp --outfile=dist/ui/bundle.js",
    "build:landing": "esbuild src/ui/Landing.tsx --bundle --format=iife --global-name=LandingApp --outfile=dist/ui/landing.js",
    "build:error": "esbuild src/ui/ErrorPage.tsx --bundle --format=iife --global-name=ErrorApp --outfile=dist/ui/error.js",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:ui": "tsc --noEmit -p tsconfig.ui.json"
  },
  "dependencies": {
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@mantine/core": "^7.11.0",
    "@mantine/hooks": "^7.11.0",
    "@mantine/dates": "^7.11.0",
    "dayjs": "^1.11.0"
  }
}